  },
  "email": "hello@example.com",
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "contactType": "customer support",
      "email": "support@example.com",
      "availableLanguage": ["English", "German"]
    },
    {
      "@type": "ContactPoint",
      "contactType": "sales",
      "email": "sales@example.com"
    },
    {
      "@type": "ContactPoint",
      "contactType": "press",
      "email": "press@example.com"
    }
  ],
  "founder": [
    {
      "@type": "Person",
      "name": "Jane Doe",
      "jobTitle": "CEO",
