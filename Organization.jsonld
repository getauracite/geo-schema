    "@type": "ImageObject",
    "url": "https://example.com/assets/logo.png",
    "width": "512",
    "height": "512"
  },
  "description": "One-sentence description of what the company does and for whom.",
  "foundingDate": "2024-01-15",
  "foundingLocation": {
    "@type": "Place",
